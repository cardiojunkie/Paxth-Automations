# Required
AI_CREDITS_API_KEY=
SESSION_SECRET=
AUTH_LOGIN_CODE=
FIREBASE_SERVICE_ACCOUNT_JSON=

# Runtime
NODE_ENV=production
PORT=3000
FIRESTORE_MODE=all
MAX_CONCURRENT_BROWSER_TASKS=1

# Reverse proxy / auth cookie behavior
TRUST_PROXY=true
COOKIE_SAME_SITE=strict
# Use false for initial HTTP-by-IP testing. Switch to true after HTTPS is enabled.
COOKIE_SECURE=false

# Set only if frontend runs on a different origin from API.
# Example: CORS_ORIGINS=https://app.example.com
CORS_ORIGINS=

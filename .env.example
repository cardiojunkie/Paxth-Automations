# ========================================
# MoosStudio Environment Configuration
# ========================================

# REQUIRED: Admin key for API security
# Generate a strong random value: openssl rand -base64 32
ADMIN_KEY=your-super-secret-admin-key-change-this

# Optional: Server port (default: 3000)
PORT=3000

# Optional: Node environment (default: development)
NODE_ENV=development

# Optional: Firestore sync mode (default: all)
# Allowed values: all | outputs-only | off
FIRESTORE_MODE=all

# Optional: Groq API Key for LLM enrichment
# Get from: https://console.groq.com/keys
# GROQ_API_KEY=your-groq-api-key-here

# Optional: CORS allowed origins (comma-separated)
# CORS_ORIGINS=https://yourdomain.com,https://another-domain.com

# Optional: Firebase service account JSON (for Firestore)
# Can be environment variable (inline JSON) or file path
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Optional: Max concurrent browser tasks (default: 2)
# MAX_CONCURRENT_BROWSER_TASKS=2

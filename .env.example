# ========================================
# MoosStudio Environment Configuration
# ========================================

# REQUIRED for AI enrichment
GROQ_API_KEY=your-groq-api-key

# Optional: Server port (default: 3000)
PORT=3000

# Optional: Node environment (default: development)
NODE_ENV=development

# Optional: Firestore sync mode (default: all)
# Allowed values: all | outputs-only | off
FIRESTORE_MODE=all

# Optional: CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Optional: Auth cookie policy
# Use strict/lax for same-origin apps; use none for cross-origin frontend + API
COOKIE_SAME_SITE=strict
COOKIE_SECURE=false

# Optional: When behind a reverse proxy or load balancer (recommended in production)
TRUST_PROXY=true

# Optional: Firebase service account JSON (for Firestore)
# Can be environment variable (inline JSON) or file path
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Optional: Max concurrent browser tasks (default: 2)
# MAX_CONCURRENT_BROWSER_TASKS=2

# Optional: Pre-warm browser on startup (recommended in production to reduce first-job latency)
# WARM_BROWSER_ON_START=true

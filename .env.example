# ========================================
# MoosStudio Environment Configuration
# ========================================

# REQUIRED for AI enrichment
AI_CREDITS_API_KEY=

# REQUIRED in production: signed session secret, minimum 32 characters
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-64-character-random-hex-secret

# REQUIRED in production: shared internal access code for allowlisted users
# Use a private 12+ character value and share it only with approved team members.
AUTH_LOGIN_CODE=replace-with-private-internal-access-code

# Optional: Server port (default: 3000)
PORT=3000

# Optional: Node environment (set to production on deployed servers)
NODE_ENV=development

# Optional: Firestore sync mode (default: all)
# Allowed values: all | outputs-only | off
FIRESTORE_MODE=all

# Optional: CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Optional: Auth cookie policy
# Use strict/lax for same-origin apps; use none for cross-origin frontend + API
COOKIE_SAME_SITE=strict
COOKIE_SECURE=false

# Optional: Set true only when behind a trusted reverse proxy/load balancer
# Keep false for direct Docker/NAT port-forward deployments to avoid spoofed client IPs.
TRUST_PROXY=false

# Optional: Firebase service account JSON (for Firestore)
# Can be environment variable (inline JSON) or file path
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Optional: Max concurrent browser tasks (default: 1, hard-capped to 2 in server code)
# MAX_CONCURRENT_BROWSER_TASKS=1

# Optional: Pre-warm browser on startup (recommended in production to reduce first-job latency)
# WARM_BROWSER_ON_START=true

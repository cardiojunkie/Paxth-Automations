# MoosStudio Environment Configuration
# Copy this file to .env and fill in your values

# Application
NODE_ENV=production
PORT=3000

# AI Credits API Key for AI enrichment
# Get one at: https://aicredits.in
AI_CREDITS_API_KEY=your-ai-credits-api-key

# Login access code for auth (minimum 12 characters, used with email to log in)
AUTH_LOGIN_CODE=your-secure-login-code

# Session Secret (generate a random string, e.g., openssl rand -hex 32)
SESSION_SECRET=your-session-secret-here

# Firebase: Points to the firebase-applet-config.json file or use GOOGLE_APPLICATION_CREDENTIALS
# Option 1: GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
# Option 2: FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Firestore mode: all, outputs-only, or off
FIRESTORE_MODE=all

# CORS origins (comma-separated URLs)
CORS_ORIGINS=

# Cookie settings
COOKIE_SAME_SITE=strict
COOKIE_SECURE=true

# Trust proxy (set true behind reverse proxies)
TRUST_PROXY=false

# Performance
MAX_CONCURRENT_BROWSER_TASKS=2
